const fib = [T] (n :: T) -> T => (
    if less[T](n, 2) then (
        1
    ) else (
        add[T](fib[T](sub[T](n, 1)), fib[T](sub[T](n, 2)))
    )
);

const TEN :: Int32 = 10;

const main = () -> () => (
    print_string("fib(10) = ");
    print_int32(fib[Int32](TEN));
    print_string("\n");
);
