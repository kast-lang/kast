const GeneratorContext = [T] @context GeneratorHandler[T];

const GeneratorHandler = [T] struct {
    .yield :: (x :: T) -> (),
};

const yield = [T] (x :: T) => (
    (@current GeneratorContext[T]).yield(x)
);

const Option = [T] struct {
    .is_some :: Bool,
    .value :: T,
};

const None = [T] () -> Option[T] => {
    .is_some = false,
    .value = uninitialized,
};

const Some = [T] (value :: T) -> Option[T] => {
    .is_some = true,
    .value = value,
};

const Iterator = [T] struct {
    .next :: () -> Option[T],
};

const GeneratorToIteratorResumeResult = [T] struct {
    .finished :: Bool,
    .value :: T,
    .new_resume :: Continuation[GeneratorToIteratorResumeResult[T]],
};

const generator_to_iterator = [T] (gen :: () -> ()) -> Iterator[T] => (
    let init :: GeneratorToIteratorResumeResult[T] = move @delimited_continuation delim (
        @capture_continuation delim resume (
            {
                .finished = uninitialized,
                .value = uninitialized,
                .new_resume = resume,
            }
        );
        with GeneratorContext[T] = {
            .yield = move (x :: T) => (
                @capture_continuation delim resume (
                    {
                        .finished = false,
                        .value = x,
                        .new_resume = resume,
                    }
                );
            ),
        };
        gen();
        {
            .finished = true,
            .value = uninitialized,
            .new_resume = uninitialized,
        }
    );
    let resume = init.new_resume;
    {
        .next = move () -> Option[T] => (
            let result = resume_continuation[GeneratorToIteratorResumeResult[T]](resume);
            resume = result.new_resume;
            if result.finished then (
                None[T]()
            ) else (
                Some[T](result.value)
            )
        ),
    }
);

const gen_10 = () => (
    let i :: Int = 0;
    unwindable loop @loop (
        if greater_or_equal[Int](i, 10) then (
            unwind loop with ();
        );
        print_String("yielding ");
        print_Int(i);
        print_String("\n");
        yield[Int](i);
        i = add[Int](i, 1);
    );
    print_String("Done yielding\n");
);

const main = () => (
    let iter = generator_to_iterator[Int](gen_10);
    unwindable loop @loop (
        let next = iter.next();
        if next.is_some then (
            print_String("iter next = ");
            print_Int(next.value);
            print_String("\n");
        ) else (
            unwind loop with ();
        )
    );
    print_String("DONE\n");
);
