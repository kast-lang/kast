# const GenericType = [T] newtype {
#     .field :: T,
# };
# const generic_fn = [T] (field :: T) -> GenericType[T] => (
#     { .field }
# );
# let x = generic_fn[Int32](123);

const GenericType = (T :: &TypeInfo) -> &TypeInfo => (
    # TODO memoization
    let result :: &TypeInfo = allocate_type_on_heap(&@TypeInfo(TypeInfo));
    let member_field :: MemberInfo = {
        .offset_or_name = initialize_offset_or_name("field"),
    };
    let members = allocate_list[MemberInfo](@native "1");
    list_index[MemberInfo](members, @native "0")^ = member_field;
    TypeInfo_init_for_struct(result, members);
    result
);

const generic_fn = (
    T :: &TypeInfo,
    field :: &Any,
    result :: &Any,
) -> () => (
    let GenericType_of_T = GenericType(T);
    let members = get_type_members(GenericType_of_T);
    let result_field = get_member(
        result,
        list_index[MemberInfo](members, @native "0"),
    );
    @"move"(T, result_field, field);
);

const const_123 :: Int32 = 123;

const GenericType_of_Int32 = struct {
    .field :: Int32,
};

const main = () -> () => (
    let x :: GenericType_of_Int32 = uninitialized;
    generic_fn(&@TypeInfo(Int32), &const_123, &x);
    @native "stmt: console.log(\(x))";
);
