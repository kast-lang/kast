const not = @call "C" (b :: Bool) -> Bool => (
    @native "!\(b)"
);

const rem = [T] @call "C" (a :: T, b :: T) -> T => (
    @native "\(a) % \(b)"
);

const max = [T] (a :: T, b :: T) -> T => (
    if greater[T](a, b) then (
        a
    ) else (
        b
    )
);

const random_int = () -> Int => (
    @native "#include <stdlib.h>";
    @native "rand()"
);

const Option = [T] struct {
    .has_value :: Bool,
    .value :: T,
};

const Treap_Node = [T] struct {
    .value :: T,
    .priority :: Int,
    .total_nodes :: Int,
    .max_depth :: Int,
    .left :: Treap[T],
    .right :: Treap[T],
};

const Treap = [T] struct {
    .is_empty :: Bool,
    .node :: Box[Treap_Node[T]],
};

const Treap_empty = [T] () -> Treap[T] => {
    .is_empty = true,
    .node = uninitialized,
};

const Treap_singleton = [T] (value :: T) -> Treap[T] => {
    .is_empty = false,
    .node = (
        let node :: &Treap_Node[T] = allocate_type_on_heap[Treap_Node[T]]();
        node^ = {
            .value = value,
            .total_nodes = 1,
            .max_depth = 1,
            .priority = random_int(),
            .left = Treap_empty[T](),
            .right = Treap_empty[T](),
        };
        node
    ),
};

const TreapSplit = [T] struct {
    .left :: Treap[T],
    .right :: Treap[T],
};

const Treap_split_at_index = [T] (
    treap :: Treap[T],
    index :: Int,
) -> TreapSplit[T] => (
    if treap.is_empty then {
        .left = treap,
        .right = treap,
    } else (
        let total_nodes_left = Treap_total_nodes[T](treap.node^.left);
        if less_or_equal[Int](index, total_nodes_left) then (
            let split = Treap_split_at_index[T](
                treap.node^.left,
                index,
            );
            treap.node^.left = Treap_empty[T]();
            {
                .left = split.left,
                .right = Treap_join[T](split.right, treap),
            }
        ) else (
            let split = Treap_split_at_index[T](
                treap.node^.right,
                sub[Int](index, add[Int](total_nodes_left, 1)),
            );
            treap.node^.right = Treap_empty[T]();
            {
                .left = Treap_join[T](treap, split.left),
                .right = split.right,
            }
        )
    )
);

const Treap_total_nodes = [T] (treap :: Treap[T]) -> Int => (
    if treap.is_empty then (
        0
    ) else (
        treap.node^.total_nodes
    )
);

const Treap_max_depth = [T] (treap :: Treap[T]) -> Int => (
    if treap.is_empty then (
        0
    ) else (
        treap.node^.max_depth
    )
);

const Treap_recalculate = [T] (treap :: Treap[T]) => (
    if not(treap.is_empty) then (
        let total_nodes_left = Treap_total_nodes[T](treap.node^.left);
        let total_nodes_right = Treap_total_nodes[T](treap.node^.right);
        treap.node^.total_nodes = add[Int](add[Int](total_nodes_left, total_nodes_right), 1);

        let max_depth_left = Treap_max_depth[T](treap.node^.left);
        let max_depth_right = Treap_max_depth[T](treap.node^.right);
        treap.node^.max_depth = add[Int](max[Int](max_depth_left, max_depth_right), 1);
    );
);

const Treap_join = [T] (
    left :: Treap[T],
    right :: Treap[T],
) -> Treap[T] => unwindable f (
    if left.is_empty then (
        unwind f with right;
    );
    if right.is_empty then (
        unwind f with left;
    );
    let result = if greater[Int](left.node^.priority, right.node^.priority) then (
        left.node^.right = Treap_join[T](left.node^.right, right);
        left
    ) else (
        right.node^.left = Treap_join[T](left, right.node^.left);
        right
    );
    Treap_recalculate[T](result);
    result
);

const String_print = (s :: String) => (
    @native "printf(\"%s\", \(s.contents))";
);

const Int_print = (x :: Int) => (
    @native "printf(\"%d\", \(x))";
);

const Treap_print_as_list_impl = [T] (
    first :: &Bool,
    treap :: Treap[T],
    T_print :: (T) -> (),
) => (
    if not(treap.is_empty) then (
        Treap_print_as_list_impl[T](first, treap.node^.left, T_print);
        if first^ then (
            first^ = false;
        ) else (
            String_print(", ");
        );
        T_print(treap.node^.value);
        Treap_print_as_list_impl[T](first, treap.node^.right, T_print);
    )
);

const Treap_print_as_list = [T] (
    treap :: Treap[T],
    T_print :: (T) -> (),
) => (
    String_print("[");
    let first = true;
    Treap_print_as_list_impl[T](&first, treap, T_print);
    String_print("]");
);

const print_string_times = (s :: String, n :: Int) => unwindable f (
    @loop (
        if equal[Int](n, 0) then (
            unwind f with ();
        );
        String_print(s);
        n = sub[Int](n, 1);
    )
);

const print_blanks = (n :: Int) => (
    print_string_times("   ", n);
);

const Treap_print_left_branch_from_parent = [T] (
    treap :: Treap[T],
) => unwindable f (
    if treap.is_empty then (
        unwind f with ();
    );
    print_blanks(Treap_total_nodes[T](treap.node^.left));
    String_print(" ╭─");
    print_string_times("───", Treap_total_nodes[T](treap.node^.right));
);

const Treap_print_right_branch_from_parent = [T] (
    treap :: Treap[T],
) => unwindable f (
    if treap.is_empty then (
        unwind f with ();
    );
    print_string_times("───", Treap_total_nodes[T](treap.node^.left));
    String_print("─╮ ");
    print_blanks(Treap_total_nodes[T](treap.node^.right));
);

const Treap_print_as_tree_at_depth = [T] (
    depth :: Int,
    treap :: Treap[T],
    T_print :: (T) -> (),
) => unwindable f (
    if treap.is_empty then (
        unwind f with ();
    );
    if equal[Int](depth, 1) then (
        Treap_print_left_branch_from_parent[T](treap.node^.left);
        String_print(" ");
        T_print(treap.node^.value);
        String_print(" ");
        Treap_print_right_branch_from_parent[T](treap.node^.right);
    ) else (
        let depth = sub[Int](depth, 1);
        Treap_print_as_tree_at_depth[T](depth, treap.node^.left, T_print);
        print_blanks(1);
        Treap_print_as_tree_at_depth[T](depth, treap.node^.right, T_print);
    );
);

const Treap_print_as_tree = [T] (
    treap :: Treap[T],
    T_print :: (T) -> (),
) => unwindable f (
    let depth :: Int = 1;
    let max_depth = Treap_max_depth[T](treap);
    @loop (
        if greater[Int](depth, max_depth) then (
            unwind f with ();
        );
        Treap_print_as_tree_at_depth[T](depth, treap, T_print);
        String_print("\n");
        depth = add[Int](depth, 1);
    );
);

const main = () => (
    let a = Treap_empty[Int]();
    let i :: Int = 0;
    unwindable loop (
        @loop (
            if less[Int](i, 30) then (
                let element = rem[Int](random_int(), 10);
                a = Treap_join[Int](a, Treap_singleton[Int](element));
            ) else (
                unwind loop with ();
            );
            i = add[Int](i, 1);
        );
    );
    Treap_print_as_list[Int](a, Int_print);
    String_print("\n");
    Treap_print_as_tree[Int](a, Int_print);
    let split = Treap_split_at_index[Int](a, 7);
    String_print("Left:\n");
    Treap_print_as_tree[Int](split.left, Int_print);
    String_print("Right:\n");
    Treap_print_as_tree[Int](split.right, (x :: Int) => Int_print(x));
);
