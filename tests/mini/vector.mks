const print = @call "C" (s :: String) -> () => (
    @native "#include <stdio.h>";
    @native "printf(\"%s\\n\", \(s.contents))";
);

const Ctx = @context String;

const Vector = [T] struct {
    .buffer :: Array[T],
    .length :: UInt,
};

const new_vector = [T] () -> Vector[T] => (
    {
        .buffer = Array_empty[T](),
        .length = 0,
    }
);

const push_vector = [T] (v :: &Vector[T], element :: T) -> () => (
    if equal[UInt](v^.length, v^.buffer.length) then (
        let new_capacity :: UInt = if equal[UInt](v^.buffer.length, 0) then (
            4
        ) else (
            mul[UInt](v^.buffer.length, 2)
        );
        let new_buffer = Array_allocate[T](new_capacity);
        let T_TypeInfo = @TypeInfo(T);
        let data_size = mul[UInt](T_TypeInfo.stride, v^.buffer.length);
        Array_copy[T](new_buffer, 0, v^.buffer, 0, v^.buffer.length);
        Array_free[T](v^.buffer);
        v^.buffer = new_buffer;
    );
    Array_index[T](v^.buffer, v^.length)^ = element;
    v^.length = add[UInt](v^.length, 1);
);

const main = () -> () => (
    print("start of main");
    let v = new_vector[Int]();
    print("created vec");
    push_vector[Int](&v, 1);
    print("added 1");
    push_vector[Int](&v, 2);
    print("added 2");
    push_vector[Int](&v, 3);
    print("added 3");
    push_vector[Int](&v, 4);
    print("added 4");
    push_vector[Int](&v, 5);
    print("added 5");
    push_vector[Int](&v, 6);
    print("added 6");
    push_vector[Int](&v, 7);
    print("added 7");

    with Ctx = "outside";
    (
        defer print("exited scope");
        print(@current Ctx);
        with Ctx = "inside";
        print(@current Ctx);
    );
    print(@current Ctx);
    print("exited main");
);
