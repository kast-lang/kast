const print_string = (s :: String) -> () => (
    @native "#include <stdio.h>";
    @native "printf(\"%s\", \(s.contents))";
);

const State = struct {
    .x :: Int,
    .y :: Int,
    .texture :: Texture2D,
    .main_loop :: &UnwindToken[()],
};

const frame = (state :: &State) -> () => (
    if WindowShouldClose() then (
        unwind (state^.main_loop) with ();
    );
    if IsKeyDown(KEY_RIGHT) then (
        state^.x = add[Int](state^.x, 1);
    );
    if IsKeyDown(KEY_LEFT) then (
        state^.x = sub[Int](state^.x, 1);
    );
    if IsKeyDown(KEY_UP) then (
        state^.y = sub[Int](state^.y, 1);
    );
    if IsKeyDown(KEY_DOWN) then (
        state^.y = add[Int](state^.y, 1);
    );
    BeginDrawing();
    let background_color :: Color = {
        .r = 10,
        .g = 10,
        .b = 30,
        .a = 0xff,
    };
    ClearBackground(background_color);
    DrawTexture(state^.texture, state^.x, state^.y, WHITE);
    EndDrawing();
);

const main = () -> () => (
    rInitWindow(512, 512, "Hello, raylib!");
    SetTargetFPS(60);
    let texture = rLoadTexture("logo.png");
    unwindable main_loop (
        let state :: State = {
            .x = 0,
            .y = 0,
            .texture = texture,
            .main_loop = main_loop,
        };
        @loop (
            frame(&state);
        );
    );
    UnloadTexture(texture);
    CloseWindow();
);
