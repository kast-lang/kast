const main = () -> () => (
    raylibInitWindow(512, 512, "Hello, raylib!");
    raylibSetTargetFPS(60);
    let texture = raylibLoadTexture("logo.png");
    let x :: Int = 0;
    let y :: Int = 0;
    @loop (
        if raylibWindowShouldClose() then (
            # TODO
            @native "stmt: break";
        );
        if raylibIsKeyDown(@native "KEY_RIGHT") then (
            x = add[Int](x, 1);
        );
        if raylibIsKeyDown(@native "KEY_LEFT") then (
            x = sub[Int](x, 1);
        );
        if raylibIsKeyDown(@native "KEY_UP") then (
            y = sub[Int](y, 1);
        );
        if raylibIsKeyDown(@native "KEY_DOWN") then (
            y = add[Int](y, 1);
        );
        raylibBeginDrawing();
        raylibClearBackground(@native "BLACK");
        raylibDrawTexture(texture, x, y, @native "WHITE");
        raylibEndDrawing();
    );
    raylibUnloadTexture(texture);
    raylibCloseWindow();
);
