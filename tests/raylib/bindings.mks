const String_to_C_String = (s :: String) -> C_String => (
    # TODO
    s.contents
);

@native
const InitWindow :: (
    width :: Int,
    height :: Int,
    title :: C_String,
) -> ();

const rInitWindow = (
    width :: Int,
    height :: Int,
    title :: String,
) -> () => (
    @native "#include <raylib.h>";
    InitWindow(width, height, String_to_C_String(title));
);

@native
const Texture2D = @opaque_type;

@native
const LoadTexture :: (path :: C_String) -> Texture2D;

const rLoadTexture = (
    path :: String,
) -> Texture2D => (
    LoadTexture(String_to_C_String(path))
);

@native
const WindowShouldClose :: () -> Bool;

@native
const BeginDrawing :: () -> ();

@native
const EndDrawing :: () -> ();

@native
const Color = struct {
    .r :: UInt8,
    .g :: UInt8,
    .b :: UInt8,
    .a :: UInt8,
};

@native
const ClearBackground :: (color :: Color) -> ();

@native
const DrawTexture :: (
    texture :: Texture2D,
    pos_x :: Int,
    pos_y :: Int,
    tint :: Color,
) -> ();

@native
const CloseWindow :: () -> ();

@native
const UnloadTexture :: (texture :: Texture2D) -> ();

@native
const IsKeyDown :: (key :: Int) -> Bool;

@native
const SetTargetFPS :: (fps :: Int) -> ();

@native
const KEY_RIGHT :: Int;

@native
const KEY_LEFT :: Int;

@native
const KEY_UP :: Int;

@native
const KEY_DOWN :: Int;

@native
const BLACK :: Color;
@native
const WHITE :: Color;
